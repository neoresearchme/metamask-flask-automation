# Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# =============================================================================
# WALLET CONFIGURATION
# =============================================================================

# Option 1: Mnemonic Seed Phrase (Recommended for testing)
# WALLET_MNEMONIC="your twelve word mnemonic seed phrase here"

# Option 2: Private Key (For single wallet)
# WALLET_PRIVATE_KEY="0xYourPrivateKeyHere"

# Option 3: Wallet JSON File Path (For keystore files)
# WALLET_FILE_PATH="/path/to/your/wallet.json"

# Option 4: Hardware Wallet (Ledger/Trezor)
# WALLET_TYPE="ledger"
# WALLET_TYPE="trezor"

# =============================================================================
# WALLET SETTINGS
# =============================================================================

# Derivation path (default: Ethereum mainnet)
WALLET_DERIVATION_PATH="m/44'/60'/0'/0/0"

# Wallet password (for encrypted keystores)
WALLET_PASSWORD=""

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# RPC URL (default: Ethereum mainnet via Infura)
RPC_URL="https://mainnet.infura.io/v3/YOUR_INFURA_KEY"

# Chain ID (1 = Ethereum mainnet, 137 = Polygon, etc.)
CHAIN_ID=1

# Gas settings (in Gwei)
GAS_PRICE=""
GAS_LIMIT=""

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================

# Session expiry in milliseconds (default: 24 hours)
SESSION_EXPIRY_MS=86400000

# Max value per transaction (in ETH, default: 0.5)
SESSION_MAX_VALUE_ETH=0.5

# Contract whitelist (comma-separated addresses)
# SESSION_ALLOWED_CONTRACTS="0xContract1,0xContract2"

# =============================================================================
# BROWSER SETTINGS
# =============================================================================

# Browser type (chromium, firefox, webkit)
BROWSER_TYPE="chromium"

# Headless mode (true/false)
BROWSER_HEADLESS="false"

# Browser window size
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080

# =============================================================================
# DAPP SETTINGS
# =============================================================================

# Default dApp URL
DEFAULT_DAPP_URL="https://app.uniswap.org/"

# Test dApp URL (for session creation)
TEST_DAPP_URL="http://localhost:3000"

# =============================================================================
# LOGGING
# =============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL="info"

# Log file path
LOG_FILE_PATH="./logs/automation.log"
